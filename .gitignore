# buildaria o instalador com o ícone padrão do Wails.
!wails_app/build/
wails_app/build/*
!wails_app/build/appicon.png
dist/
*.exe
build_env/
build_env_*/

# ----- Dados gerados em runtime -----
exportacao/*.csv
